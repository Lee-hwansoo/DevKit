# =============================================================================
# .editorconfig
# Universal editor configuration
# =============================================================================

root = true

# =============================================================================
# Default: All files
# =============================================================================
[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

# =============================================================================
# C / C++
# =============================================================================
[*.{c,cpp,h,hpp,cc,hh,cxx,hxx}]
indent_size = 4

# =============================================================================
# Python / ROS2 launch files
# =============================================================================
[*.{py,launch.py}]
indent_size = 4

# =============================================================================
# CMake
# =============================================================================
[CMakeLists.txt]
indent_size = 2

[*.cmake]
indent_size = 2

# =============================================================================
# Configuration / Markup
# =============================================================================
[*.{yaml,yml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.xml]
indent_size = 2

# =============================================================================
# ROS2 Robot formats
# =============================================================================
[*.{urdf,xacro,world,sdf,launch}]
indent_size = 2

[*.rviz]
indent_size = 2

# =============================================================================
# Shell scripts
# =============================================================================
[*.sh]
indent_size = 4

# =============================================================================
# Makefile (tab)
# =============================================================================
[Makefile]
indent_style = tab
