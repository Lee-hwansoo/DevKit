# =============================================================================
# .env.example
# Primary template for project-specific environment variables

# [Usage Instructions]
#   1. `make setup` or `cp .env.example .env`
#   2. Edit .env and change COMPOSE_PROJECT_NAME to isolate your project.
#   3. .env is git-ignored for security and configuration isolation.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 1. CORE PROJECT SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

# COMPOSE_PROJECT_NAME: Unique identifier for Docker resources (Required to change)
# Changing this value completely isolates the Docker environment for a new project.
COMPOSE_PROJECT_NAME=myproject

# WORKSPACE_PATH: Absolute path to the host project (Optional, Default: current folder)
# Usually unnecessary to change. Use it only when forcing a path in a CI environment.
# WORKSPACE_PATH=/path/to/project

# ROS & OS Version: Determine the ROS environment to use (must be paired properly)
# [Option A] ROS 2 (Default)
BASE_IMAGE=ubuntu:22.04
ROS_DISTRO=humble

# [Option B] ROS 1 (Legacy Support)
# BASE_IMAGE=ubuntu:20.04
# ROS_DISTRO=noetic

# ─────────────────────────────────────────────────────────────────────────────
# 2. HARDWARE & DISPLAY (GPU Acceleration)
# ─────────────────────────────────────────────────────────────────────────────

# TARGETARCH: Docker image architecture (Default: host architecture auto-detected)
# TARGETARCH=amd64

# GPU_MODE: Hybrid GPU Acceleration Mode
#   auto  : Auto detection (Default) — NVIDIA > Intel > AMD > CPU sequence
#   nvidia: Force NVIDIA GPU (requires nvidia-container-toolkit)
#   intel : Force Intel GPU acceleration (For Intel iGPUs)
#   amd   : Force AMD GPU acceleration
#   cpu   : Force Software Rendering (always works, for low-end devices/debugging)
GPU_MODE=auto

# [Advanced GPU Tuning] - Used for multi-GPU setups or specific acceleration features
#   NVIDIA_VISIBLE_DEVICES: GPU numbers to use or 'all' (Default: all)
#   NVIDIA_GPU_COUNT: Number of GPUs to allocate (Default: all)
#   NVIDIA_DRIVER_CAPABILITIES: Scope of acceleration features (Default: all)
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_GPU_COUNT=all
# NVIDIA_DRIVER_CAPABILITIES=all

# Display number for GUI integration (Default: :0) and display type
# Automatically inherited from the host environment, uncomment below if manual setting is required.
# DISPLAY=:0
# DISPLAY_TYPE=X11

# [Advanced Display Settings] - Auto-detected by Makefile but can be overridden manually
# HOST_XAUTHORITY=${HOME}/.Xauthority
# HOST_WAYLAND_DISPLAY=wayland-0
# HOST_XDG_RUNTIME_DIR=/run/user/1000

# ─────────────────────────────────────────────────────────────────────────────
# 3. ROS NETWORKING & COMMUNICATION
# ─────────────────────────────────────────────────────────────────────────────

# [ROS 2 Specific]
# ROS_DOMAIN_ID: Prevents network clashes in multi-project or multi-team collaboration (0~101)
ROS_DOMAIN_ID=0
# RMW_IMPLEMENTATION: ROS 2 Middleware (Default: CycloneDDS for better stability instead of FastDDS)
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# [ROS 1 Specific]
# ROS_MASTER_URI: ROS 1 Master (roscore) Address
ROS_MASTER_URI=http://localhost:11311
# ROS_HOSTNAME: Network identifier name of the container
ROS_HOSTNAME=localhost
# ROS_IP: Host IP needed for communication with external devices (uncomment if necessary)
# ROS_IP=127.0.0.1

# [Docker Infrastructure]
NETWORK_MODE=host
IPC_MODE=host
PRIVILEGED=true
ULIMIT_NOFILE=65535

# ─────────────────────────────────────────────────────────────────────────────
# 4. HYBRID WORKSPACE (Volumes & Cache)
# ─────────────────────────────────────────────────────────────────────────────

# [Clean Workspace Strategy]
# Empty value (Default): Named Volume — Build artifacts stay fully isolated inside Docker.
#   → Maintains a clean host directory and is best for data isolation between containers.
# Specific path: Bind Mount — Directly connects to a folder on the host.
#   → Use when you need IDE code completion or direct file access from the host.
#   → Example: ROS_BUILD_VOL=./build
ROS_BUILD_VOL=
ROS_INSTALL_VOL=
ROS_LOG_VOL=
DEV_BUILD_VOL=
DEV_INSTALL_VOL=
DEV_LOG_VOL=
PROD_LOG_VOL=

# [Third-party Dependencies]
# Relative path inside the workspace to clone the dependency sources to (Default: src/thirdparty)
# SYNC_TARGET_DIR=src/thirdparty

# [Cache & Performance]
# Directory for Docker build/runtime caches (ccache, uv, apt, etc.)
# Default: .docker_cache within the current project root.
# Only uncomment below if you want to share a common absolute path across multiple projects.
# DOCKER_DEV_CACHE_DIR=/home/user/.global_docker_cache

# ─────────────────────────────────────────────────────────────────────────────
# 5. SYSTEM & BUILD TOOLS
# ─────────────────────────────────────────────────────────────────────────────

# APT_SNAPSHOT_DATE: Fix Ubuntu package versions to a specific date (Strict Determinism)
# Enter UTC date to freeze the environment, or 'latest' to always get the newest versions.
# Example: APT_SNAPSHOT_DATE=20240301T000000Z
APT_SNAPSHOT_DATE=latest

# Locale & Timezone: By default, we use C.UTF-8 and UTC for standard project environments.
# LANG=C.UTF-8: Supports Unicode (e.g., Korean) inputs while keeping system messages (errors) in English for easier debugging.
LANG=C.UTF-8
TZ=UTC

# [Option] If system messages must respond in Korean (Not recommended, change before building)
# LANG=ko_KR.UTF-8

# [Build Specs] - By default, automatically detected and injected by the Makefile.
# CMAKE_CXX_STANDARD: Passed as -DCMAKE_CXX_STANDARD in colcon build (Supported: 17, 20)
CMAKE_CXX_STANDARD=17
UV_VERSION=0.10.10
UV_PYTHON=3.10

# [Build Flags] - Manage dependencies and build options per project.
# Python dependency synchronization flags (e.g., --extra gpu, --extra cpu)
UV_SYNC_FLAGS=
# Extra CMake arguments (e.g., -DUSE_CUDA=ON)
CMAKE_EXTRA_ARGS=
# Extra ROS colcon build arguments (e.g., --executor sequential)
COLCON_EXTRA_FLAGS=

# ─────────────────────────────────────────────────────────────────────────────
# 6. PRODUCTION & RUNTIME (Production Only)
# ─────────────────────────────────────────────────────────────────────────────

# IMAGE_TAG: Tag to use for production image building (Default: latest)
IMAGE_TAG=latest

# [PROD] Production image run command (Edit strictly to your App requirements)
# Container execution smoothly halts if no startup command is set.
# (Example)
# ROS_LAUNCH_COMMAND=ros2 launch bringup main.launch.py
# APP_COMMAND=python3 main.py

# (If you want to enter an idle state - Not Recommended)
# ROS_LAUNCH_COMMAND=bash
# APP_COMMAND=bash

# ─────────────────────────────────────────────────────────────────────────────
# 7. HOST INTEGRATION (Git & SSH)
# ─────────────────────────────────────────────────────────────────────────────

# Shares the host's configuration (Read-Only) to Git Commit/Push inside the container.
# Designed with a Smart Default to keep your original user setup even after using sudo.
# It reads standard file locations (~/.gitconfig, ~/.ssh) from the host.
# Default values: ${HOST_HOME}/.gitconfig and ${HOST_HOME}/.ssh
# If you want to use a specific location, uncomment below and set absolute paths.
# GIT_CONFIG_PATH=${HOST_HOME}/.gitconfig
# SSH_PATH=${HOST_HOME}/.ssh

# ─────────────────────────────────────────────────────────────────────────────
# 8. LOGGING & DIAGNOSTICS
# ─────────────────────────────────────────────────────────────────────────────

# LOG_SHOW_TIME: Display timestamps in log outputs (true | false)
LOG_SHOW_TIME=false

# DEBUG_MODE: Enable verbose debug log (log_debug) outputs (true | false)
DEBUG_MODE=false

# LOG_FILE: Designate a path to output logs to a file.
# If you indicate a directory within the container (e.g., /workspace/log/dev.log), you can check them on the hose.
# LOG_FILE=/workspace/log/setup.log
