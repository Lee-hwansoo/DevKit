# =============================================================================
# .env.example
# Primary template for project-specific environment variables

# [Usage Instructions]
#   1. `make setup` or `cp .env.example .env`
#   2. Edit .env and change COMPOSE_PROJECT_NAME to isolate your project.
#   3. .env is git-ignored for security and configuration isolation.
#
# [Security Notice]
#   This file may contain sensitive values (API keys, tokens, etc.).
#   NEVER commit .env to version control. Use Docker Secrets or a vault
#   for production secret management. See: https://docs.docker.com/compose/how-tos/use-secrets/
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 1. CORE PROJECT SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

#   COMPOSE_PROJECT_NAME: Unique identifier for Docker resources (Required to change)
#   Changing this value completely isolates the Docker environment for a new project.
#   Allowed: lowercase letters, digits, dashes (-), and underscores (_).
#   Must start and end with a lowercase letter or digit.
COMPOSE_PROJECT_NAME=myproject

#   CONTAINER_USER: Username for the non-root developer user inside the container.
#   Files created inside the container will be owned by this user.
#   For host/container file compatibility, the user's UID and GID are dynamically
#   detected from the host (via Makefile `id -u` / `id -g`) at build time.
#   You can manually override them by exporting HOST_UID and HOST_GID in your shell if needed.
CONTAINER_USER=user

#   HOST_WORKSPACE_PATH: Absolute path to the project on your HOST machine.
#   Used for Docker volume mounting. (Default: current folder)
# HOST_WORKSPACE_PATH=/home/user/DevKit

#   WORKSPACE_PATH: Absolute path to the project INSIDE the container.
#   SSOT for all internal tools and scripts. (Default: /workspace)
# WORKSPACE_PATH=/workspace

# [ROS & OS Version]
#   Determine the ROS environment to use (must be paired properly)
#   [Option A] ROS 2 (Default)
BASE_IMAGE=ubuntu:22.04
ROS_DISTRO=humble

#   [Option B] ROS 1 (Legacy Support)
# BASE_IMAGE=ubuntu:20.04
# ROS_DISTRO=noetic

#   For reproducible builds, pin the base image by digest:
# BASE_IMAGE=ubuntu:22.04@sha256:<digest>
#   Get current digest: docker pull ubuntu:22.04 && docker inspect --format='{{index .RepoDigests 0}}' ubuntu:22.04

# ─────────────────────────────────────────────────────────────────────────────
# 2. HARDWARE & DISPLAY (GPU Acceleration)
# ─────────────────────────────────────────────────────────────────────────────

#   TARGETARCH: Docker image architecture (Default: host architecture auto-detected)
# TARGETARCH=amd64

# GPU_MODE: Hybrid GPU Acceleration Mode
#   auto  : Auto detection (Default) — NVIDIA > Intel > AMD > CPU sequence
#   nvidia: Force NVIDIA GPU (requires nvidia-container-toolkit)
#   intel : Force Intel GPU acceleration (For Intel iGPUs)
#   amd   : Force AMD GPU acceleration
#   cpu   : Force Software Rendering (always works, for low-end devices/debugging)
GPU_MODE=auto

#   INSTALL_INTEL_GPU_TOOLS: Include Intel iGPU diagnostics/OpenCL packages in
#   direct Docker/SIF builds. Compose iGPU profiles enable this automatically.
# INSTALL_INTEL_GPU_TOOLS=false

# [CUDA/OpenCV Build Settings]
#   OPENCV_CUDA: Controls OpenCV CUDA CMake flags for in-container builds.
#     auto : Enable only when NVIDIA runtime and nvcc are both available.
#     off  : Always build OpenCV-dependent projects with -DWITH_CUDA=OFF.
OPENCV_CUDA=auto

# [CUDA Toolkit Image Settings] - Only effective when HAS_NVIDIA=true and CUDA_VERSION is set
#   FULL_CUDA: Install complete CUDA toolkit in development images (1/true) or minimal dev toolkit/libs (false)
#   PROD_FULL_CUDA: Install complete CUDA toolkit in production SIFs (1/true). Default off for smaller delivery artifacts.
#   CUDA_VERSION: Target CUDA version (e.g., 11.8.0, 12.1.1, 12.8.0)
#   CUDNN_VERSION: Target cuDNN major version (e.g., 8, 9)
# FULL_CUDA=false
# PROD_FULL_CUDA=false
# CUDA_VERSION=12.8.0
# CUDNN_VERSION=9

# [Advanced GPU Tuning] - Used for multi-GPU setups or specific acceleration features
#   NVIDIA_VISIBLE_DEVICES: GPU numbers to use or 'all' (Default: all)
#   NVIDIA_GPU_COUNT: Number of GPUs to allocate (Default: all)
#   NVIDIA_DRIVER_CAPABILITIES: Scope of acceleration features (Default: all)
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_GPU_COUNT=all
# NVIDIA_DRIVER_CAPABILITIES=all

#   Display number for GUI integration (Default: :0) and display type
#   Automatically inherited from the host environment, uncomment below if manual setting is required.
# DISPLAY=:0
# DISPLAY_TYPE=X11

# [Advanced Display Settings] - Auto-detected by Makefile but can be overridden manually
# HOST_XAUTHORITY=${HOME}/.Xauthority       # Must be an existing file when set
# HOST_WAYLAND_DISPLAY=wayland-0
# HOST_XDG_RUNTIME_DIR=/run/user/1000       # Must be an existing directory when set
# HOST_X11_DIR=/tmp/.X11-unix               # Must be an existing directory when set
# HOST_SSH_AUTH_SOCK=/run/user/1000/keyring/ssh  # Must be an existing UNIX socket when set

# ─────────────────────────────────────────────────────────────────────────────
# 3. ROS NETWORKING & COMMUNICATION
# ─────────────────────────────────────────────────────────────────────────────

# [Docker Infrastructure]
NETWORK_MODE=host
IPC_MODE=host
PRIVILEGED=true
ULIMIT_NOFILE=65535

# [ROS 2 Specific]
#   ROS_DOMAIN_ID: Prevents network clashes in multi-project or multi-team collaboration (0~101)
#   RMW_IMPLEMENTATION: ROS 2 Middleware (Default: CycloneDDS for better stability instead of FastDDS)
# ROS_DOMAIN_ID=0
# RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# [ROS 1 Specific]
#   ROS_MASTER_URI: ROS 1 Master (roscore) Address
#   ROS_HOSTNAME: Network identifier name of the container
#   ROS_IP: Host IP needed for communication with external devices (uncomment if necessary)
# ROS_MASTER_URI=http://localhost:11311
# ROS_HOSTNAME=localhost
# ROS_IP=127.0.0.1

# ─────────────────────────────────────────────────────────────────────────────
# 4. HYBRID WORKSPACE (Volumes & Cache)
# ─────────────────────────────────────────────────────────────────────────────

# [Clean Workspace Strategy]
# Empty value (Default): Named Volume — Build artifacts stay fully isolated inside Docker.
#   → Maintains a clean host directory and is best for data isolation between containers.
# Specific path: Bind Mount — Directly connects to a folder on the host.
#   → Use when you need IDE code completion or direct file access from the host.
#   → Example: ROS_BUILD_VOL=./build
ROS_BUILD_VOL=
ROS_INSTALL_VOL=
ROS_LOG_VOL=
DEV_BUILD_VOL=
DEV_INSTALL_VOL=
DEV_LOG_VOL=

# [Third-party Dependencies]
#   Relative path inside the workspace to clone the dependency sources to (Default: src/thirdparty)
# SYNC_TARGET_DIR=src/thirdparty
#   Fail-open switches for exceptional dependency sync situations.
#   Default behavior fails fast on vcs/rosdep errors to avoid partial environments.
# DEVKIT_VCS_ALLOW_FAILURE=0
# DEVKIT_ROSDEP_ALLOW_FAILURE=0

# [Cache & Performance]
#   Directory for Docker build/runtime caches (ccache, uv, apt, etc.)
#   Default: .docker_cache within the current project root.
#   If set, this must be an absolute, non-root path.
#   DevKit refuses relative paths and the workspace root; shared
#   cache paths are allowed but will be warned before deletion.
# DOCKER_DEV_CACHE_DIR=/home/user/.global_docker_cache

# ─────────────────────────────────────────────────────────────────────────────
# 5. SYSTEM & BUILD TOOLS
# ─────────────────────────────────────────────────────────────────────────────

# APT_SNAPSHOT_DATE: Fix Ubuntu APT package versions to a specific date.
#   NOTE: the default 'latest' is NOT reproducible — it tracks the rolling Ubuntu
#   archive, so two builds on different days can differ. Use 'latest' for active
#   development; PIN a UTC date (date -u +%Y%m%dT%H%M%SZ -> 20260714T030000Z) on
#   release branches for deterministic Ubuntu packages.
#   SCOPE: this pins ONLY the Ubuntu archive. The ROS/CUDA repos, 'uv', the Python
#   toolchain, rosdep, and downloaded fonts are still fetched live and are NOT pinned
#   here — so a pinned date alone does not guarantee a fully reproducible image.
#   Example: APT_SNAPSHOT_DATE=20260714T030000Z
APT_SNAPSHOT_DATE=latest

#   LANG: Supports Unicode (e.g., Korean/Emoji) while keeping system messages in English.
LANG=C.UTF-8
#   TZ: System timezone (Default: UTC)
TZ=UTC
#   DEBIAN_FRONTEND: Prevents interactive prompts during package installation (Strictly non-interactive)
DEBIAN_FRONTEND=noninteractive

# [Option] If system messages must respond in Korean (Not recommended, change before building)
# LANG=ko_KR.UTF-8

# [Build Specs] - By default, automatically detected and injected by the Makefile.
#   CMAKE_CXX_STANDARD: Passed as -DCMAKE_CXX_STANDARD in colcon build (Supported: 17, 20)
#   CMAKE_C_STANDARD: Passed as -DCMAKE_C_STANDARD (Supported: 11, 17)
CMAKE_CXX_STANDARD=17
CMAKE_C_STANDARD=11

# [Python Specs] - By default, automatically detected and injected by the Makefile.
#   SYS_PYTHON_EXE: Path to system python executable in Container
#   UV_VERSION: uv version to use in Container
#   UV_PYTHON: Python version for uv (in Container)
SYS_PYTHON_EXE=/usr/bin/python3
UV_VERSION=0.10.10
UV_PYTHON=3.10

# [Build Flags] - Manage dependencies and build options per project.
#   Python dependency synchronization flags (e.g., --extra gpu, --extra cpu)
UV_SYNC_FLAGS=
#   Extra CMake arguments (e.g., -DUSE_CUDA=ON)
CMAKE_EXTRA_ARGS=
#   Extra ROS colcon build arguments (e.g., --executor sequential)
COLCON_EXTRA_FLAGS=

# [Security] ROS GPG key verification policy during Docker image build.
#   On a ROS-key fingerprint mismatch (key rotation OR tampering):
#     false = warn but continue (fail-open; resilient to ROS key rotation)
#     true  = abort the build (fail-closed; blocks key substitution)
#   MODE-AWARE DEFAULTS: production SIF bakes ('make bake-prod') default to 'true'
#   (fail-closed — deployable artifacts warrant strict verification), while dev
#   image builds and 'make bake-dev' default to 'false' (availability during
#   iteration). Set this variable to override either default explicitly.
#   NOTE: apt still verifies package signatures against the key in BOTH cases;
#   this pin only detects whether the key itself was swapped. On a real rotation,
#   run 'make update-gpg' to refresh the pinned fingerprint.
# STRICT_GPG_CHECK=false

# [TERMINAL]: Terminal emulator launched by `make term ENV=ros|dev`
#   Must be a terminal emulator installed inside the dev container image.
# TERMINAL=terminator

# ─────────────────────────────────────────────────────────────────────────────
# 6. PRODUCTION & RUNTIME (Production Only)
# ─────────────────────────────────────────────────────────────────────────────

#   IMAGE_TAG: Tag to use for production image building (Default: latest)
#   Must be a valid Docker tag: start with alnum/_; use alnum, _, ., -; max 128 chars.
IMAGE_TAG=latest
#   SOURCE_DATE_EPOCH: Optional Unix timestamp for reproducible release metadata.
#   Example: SOURCE_DATE_EPOCH=$(git log -1 --format=%ct)
# SOURCE_DATE_EPOCH=

#   SIF_MODE: Select run target for `make run-sif` (dev | prod | slurm).
#   ENV selects the prod SIF family when SIF_MODE=prod|slurm.
# SIF_MODE=dev
#   SIF_FILE: Override generated SIF filename when needed.
# SIF_FILE=myproject_ros_prod_latest.sif

#   [PROD] Production image run command (Edit strictly to your App requirements).
#   ROS_LAUNCH_COMMAND has priority over APP_COMMAND. Production/slurm runs fail
#   fast unless a command is configured here or passed with RUN_ARGS.
#   (Example)
# ROS_LAUNCH_COMMAND=ros2 launch bringup main.launch.py
# APP_COMMAND=python3 main.py

#   [SLURM] Optional host paths mounted into production SIF jobs.
#   Submission logs show requested resources; job logs show actual allocation.
# DEVKIT_SLURM_JOB_NAME=devkit
# DEVKIT_SLURM_PARTITION=local
# DEVKIT_SLURM_NODES=1
# DEVKIT_SLURM_NTASKS=1
# DEVKIT_SLURM_CPUS_PER_TASK=4
# DEVKIT_SLURM_GRES=gpu:1
# DEVKIT_SLURM_TIME=00:30:00
# DEVKIT_SLURM_OUTPUT=logs/%x_%j.out
# DEVKIT_SLURM_ERROR=logs/%x_%j.err
# DEVKIT_SLURM_COMMENT=submitter:devkit
# SLURM_DATA_ROOT=/path/to/read-only/data
# SLURM_RUN_ROOT=/path/to/writeable/runs
# CONTAINER_DATA_ROOT=/workspace/data
# CONTAINER_RUN_ROOT=/runs

# ─────────────────────────────────────────────────────────────────────────────
# 7. HOST INTEGRATION (Git & SSH Agent)
# ─────────────────────────────────────────────────────────────────────────────

# [SSH Authentication]
#   This project uses the host's SSH Agent for secure authentication inside the container.
#   No manual path configuration is required as long as `ssh-agent` is running on the host.
#   To add your keys, run: `ssh-add ~/.ssh/id_rsa` (on the host) before `make start ENV=ros`.

# [Git Configuration]
#   Shares the host's configuration (Read-Only) for Git Identity (Commit/Push) inside the container.
#   It automatically reads standard file locations (~/.gitconfig) from the host.
#   Default value: ${HOST_HOME}/.gitconfig
#   If you want to use a specific location, uncomment below and set an existing file path.
# GIT_CONFIG_PATH=${HOST_HOME}/.gitconfig

# ─────────────────────────────────────────────────────────────────────────────
# 8. LOGGING & DIAGNOSTICS
# ─────────────────────────────────────────────────────────────────────────────

#   LOG_SHOW_TIME: Display timestamps in log outputs (true | false)
LOG_SHOW_TIME=false

#   DEBUG_MODE: Enable verbose debug log (log_debug) outputs (true | false)
DEBUG_MODE=false

#   LOG_FILE: Output logs to a file (Relative to WORKSPACE_PATH).
#   Example: log/setup.log will be stored in ${WORKSPACE_PATH}/log/setup.log.
# LOG_FILE=log/setup.log
