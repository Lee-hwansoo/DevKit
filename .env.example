# =============================================================================
# ros2_docker_template/.env.example
#
# 사용법:
#   cp .env.example .env
#   .env 파일을 열어 WORKSPACE_PATH, COMPOSE_PROJECT_NAME 수정
#
# .env는 .gitignore에 포함됨 — 절대 커밋하지 마세요
# =============================================================================

# ── Project Name (볼륨/컨테이너 이름 접두사) ──────────────────────────────
# Docker Compose가 모든 볼륨/컨테이너에 자동으로 이 값을 prefix로 사용
# 예: myproject → 볼륨명: myproject_ros_build_humble, myproject_cache ...
# 프로젝트 전환 시 이 값만 변경하면 볼륨이 완전히 분리됨
COMPOSE_PROJECT_NAME=myproject

# ── Workspace ────────────────────────────────────────────────────────────────
# 호스트의 프로젝트 소스 코드 경로 (절대 경로)
# 모든 서비스는 컨테이너 내 /workspace 로 경로가 단일화되었습니다.
WORKSPACE_PATH=/home/yourname/projects/my_project

# ── ROS & OS Version (SSOT) ──────────────────────────────────────────────────
# 어떤 ROS 환경을 사용할지 결정합니다. 반드시 페어로 맞추어야 합니다.
# 1) ROS 2 (기본)
BASE_IMAGE=ubuntu:22.04
ROS_DISTRO=humble

# 2) ROS 1 (레거시 전환 시)
# BASE_IMAGE=ubuntu:20.04
# ROS_DISTRO=noetic
# ─────────────────────────────────────────────────────────────────────────────

# ── ROS 2 Communication (ROS 2 전용) ─────────────────────────────────────────
# ROS_DOMAIN_ID: 다중 프로젝트 실행 시 고유한 ID(0~101)를 설정하여 네트워크 충돌 방지
ROS_DOMAIN_ID=0
# RMW_IMPLEMENTATION: ROS 2 미들웨어 설정 (기본: CycloneDDS)
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# ── ROS 1 Communication (ROS 1 전용) ─────────────────────────────────────────
# ROS_MASTER_URI: ROS 1 마스터(roscore) 주소
ROS_MASTER_URI=http://localhost:11311
# ROS_HOSTNAME: 컨테이너의 네트워크 식별 이름
ROS_HOSTNAME=localhost
# ROS_IP: 실제 장비와 통신 시 필요한 호스트 IP (필요 시 주석 해제)
# ROS_IP=127.0.0.1

# ── APT Snapshot (Strict Determinism) ────────────────────────────────────────
# 특정 날짜 기준의 패키지 버전으로 자동 고정 (latest 설정 시 최신 버전 사용)
# 재현성이 중요한 배포/운영 단계에서는 날짜 명시를 권장합니다.
# 예: 20240301T000000Z
APT_SNAPSHOT_DATE=latest

# ── Hybrid Volumes (IDE Connectivity) ────────────────────────────────────
# 기본값은 성능 최적화를 위한 Named Volume(예: ros_build_data) 입니다.
# ROS 버전과 무관하게 공통의 볼륨을 사용하도록 통일되었습니다.
# 버전에 따라 볼륨을 분리하거나 IDE 인텔리센스 지원을 위해 호스트 디렉토리를 연결하려면,
# 아래 변수에 원하는 이름이나 호스트 상대 경로를 입력하세요.
# 예: ROS_BUILD_VOL=ros_build_humble 또는 ROS_INSTALL_VOL=./.build_output/install
ROS_BUILD_VOL=
ROS_INSTALL_VOL=
ROS_LOG_VOL=
DEV_BUILD_VOL=
DEV_INSTALL_VOL=

# ── Display ───────────────────────────────────────────────────────────────────
# X11 (기본): :0 또는 :1
DISPLAY=:0
# X11 권한 파일 (일반적으로 ~/.Xauthority)
XAUTHORITY_PATH=${HOME}/.Xauthority
# Wayland 디스플레이 자동 상속 (호스트가 Wayland일 경우 자동 적용됨)
WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-}
XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-}

# ── GPU ───────────────────────────────────────────────────────────────────────
# auto  : 자동 감지 (기본) — NVIDIA > Intel > AMD > CPU 순서
# nvidia: NVIDIA GPU 강제 (nvidia-container-toolkit 필요)
# intel : Intel GPU 강제 (Mesa/iris — 통합 GPU 및 Arc 지원)
# amd   : AMD GPU 강제 (Mesa/radeonsi)
# cpu   : 소프트웨어 렌더링 강제 (항상 동작, GPU 없을 때)
GPU_MODE=auto

# ── Cache & Performance ──────────────────────────────────────────────────
# 도커 캐시 저장 경로 (ccache, uv, apt 등)
# 기본값: 프로젝트 루트 내 .docker_cache
# 여러 프로젝트 간 캐시를 공유하려면 호스트의 공통 경로를 지정하세요.
DOCKER_DEV_CACHE_DIR=${WORKSPACE_PATH}/.docker_cache

# ── Locale ────────────────────────────────────────────────────────────────────
LANG=ko_KR.UTF-8
# 영어: LANG=en_US.UTF-8

# ── Build Tools ──────────────────────────────────────────────────────────────
# CMAKE_CXX_STANDARD: colcon build 시 -DCMAKE_CXX_STANDARD 로 전달됨 (지원: 17, 20)
CMAKE_CXX_STANDARD=17
# UV_PYTHON: uv가 컨테이너 빌드 시 사전 설치하는 Python 버전
UV_PYTHON=3.11
# UV_VERSION: uv 자체 버전
UV_VERSION=0.10.10

# ── Git / SSH (호스트 → 컨테이너 read-only 마운트) ───────────────────────────
# 컨테이너에서 git commit/push를 위해 호스트 설정을 공유
# 표준 경로(~/.gitconfig, ~/.ssh)면 변경 불필요
GIT_CONFIG_PATH=${HOME}/.gitconfig
SSH_PATH=${HOME}/.ssh
