# =============================================================================
# ros2_docker_template/.env.example
#
# [사용법]
#   [명령어]
#   make setup
#   [직접 복사]
#   1. cp .env.example .env
#   2. .env 파일을 열어 프로젝트 이름(COMPOSE_PROJECT_NAME) 등을 수정
#   3. .env는 .gitignore에 포함되어 있으므로 보안 공유 시 주의하세요.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 1. CORE PROJECT SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

# COMPOSE_PROJECT_NAME: 도커 리소스(컨테이너, 볼륨)의 고유 식별자 (필수 변경)
# 프로젝트 전환 시 이 값만 변경하면 도커 환경이 완전히 분리됩니다.
COMPOSE_PROJECT_NAME=myproject

# WORKSPACE_PATH: 프로젝트의 호스트 절대 경로 (선택 사항, 기본값: 현재 폴더)
# 일반적인 경우 수정이 불필요하며, 특정 CI 환경 등에서 경로를 강제할 때만 사용하세요.
# WORKSPACE_PATH=/path/to/project

# ROS & OS Version: 어떤 ROS 환경을 사용할지 결정 (반드시 페어로 맞추어야 함)
# [Option A] ROS 2 (기본)
BASE_IMAGE=ubuntu:22.04
ROS_DISTRO=humble

# [Option B] ROS 1 (레거시 전환 시)
# BASE_IMAGE=ubuntu:20.04
# ROS_DISTRO=noetic


# ─────────────────────────────────────────────────────────────────────────────
# 2. HARDWARE & DISPLAY (GPU Acceleration)
# ─────────────────────────────────────────────────────────────────────────────

# GPU_MODE: 하이브리드 GPU 가속 모드 선택
#   auto  : 자동 감지 (기본) — NVIDIA > Intel > AMD > CPU 순서
#   nvidia: NVIDIA GPU 강제 (nvidia-container-toolkit 필요)
#   intel : Intel GPU 가속 강제 (Intel iGPU 전 전용)
#   amd   : AMD GPU 가속 강제
#   cpu   : 소프트웨어 렌더링 강제 (항상 동작, 저사양/디버깅용)
GPU_MODE=auto

# [Advanced GPU Tuning] - 다중 GPU 장비나 특정 가속 기능 제어 시 사용
# NVIDIA_VISIBLE_DEVICES: 사용할 GPU 번호 또는 'all' (기본: all)
# NVIDIA_GPU_COUNT: 할당할 GPU 개수 (기본: all)
# NVIDIA_DRIVER_CAPABILITIES: 가속 기능 범위 (기본: all)
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_GPU_COUNT=all
# NVIDIA_DRIVER_CAPABILITIES=all

# GUI 연동을 위한 디스플레이 번호 (기본: :0) 및 디스플레이 타입
# 호스트 환경에서 자동으로 상속되나, 필요 시 아래 주석을 풀고 강제 지정하세요.
# DISPLAY=:0
# DISPLAY_TYPE=X11

# [Advanced Display Settings] - Makefile 실행 시 자동 감지되나 수동 설정 가능
# HOST_XAUTHORITY=${HOME}/.Xauthority
# HOST_WAYLAND_DISPLAY=wayland-0
# HOST_XDG_RUNTIME_DIR=/run/user/1000


# ─────────────────────────────────────────────────────────────────────────────
# 3. ROS NETWORKING & COMMUNICATION
# ─────────────────────────────────────────────────────────────────────────────

# [ROS 2 전용]
# ROS_DOMAIN_ID: 다중 프로젝트 또는 다중 팀 협업 시 네트워크 충돌 방지 (0~101)
ROS_DOMAIN_ID=0
# RMW_IMPLEMENTATION: ROS 2 미들웨어 (기본: FastDDS 대신 더 안정적인 CycloneDDS 사용)
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# [ROS 1 전용]
# ROS_MASTER_URI: ROS 1 마스터(roscore) 주소
ROS_MASTER_URI=http://localhost:11311
# ROS_HOSTNAME: 컨테이너의 네트워크 식별 이름
ROS_HOSTNAME=localhost
# ROS_IP: 실제 타 장비와 통신 시 필요한 호스트 IP (필요 시 주석 해제)
# ROS_IP=127.0.0.1

# [Docker Infrastructure]
NETWORK_MODE=host
IPC_MODE=host
PRIVILEGED=true


# ─────────────────────────────────────────────────────────────────────────────
# 4. HYBRID WORKSPACE (Volumes & Cache)
# ─────────────────────────────────────────────────────────────────────────────

# [Clean Workspace 전략]
# 기본값은 Named Volume을 사용하며, 호스트 파일 시스템 오염 방지를 위해
# 빌드 결과물을 격리된 경로(/opt/dockervol)에 저장합니다.
#
# 만약 호스트와 직접 연결(Bind Mount)하여 IDE 인텔리센스 지원 등을 받고 싶다면,
# 아래 변수에 호스트 상대 경로(예: ./build)를 입력하세요.
# 예: ROS_BUILD_VOL=./build
ROS_BUILD_VOL=
ROS_INSTALL_VOL=
ROS_LOG_VOL=
DEV_BUILD_VOL=
DEV_INSTALL_VOL=
DEV_LOG_VOL=
PROD_LOG_VOL=

# [Dynamic Volume Mount Root] (기본: /opt/dockervol)
# 컨테이너 내 빌드 결과물이 마운트되는 최상위 경로를 변경하고 싶을 때 사용하세요.
# DOCKER_VOL_MOUNT_ROOT=/opt/dockervol

# [Third-party Dependencies]
# 의존성 소스 코드가 동기화될 워크스페이스 내 상대 경로 (기본: src/thirdparty)
# SYNC_TARGET_DIR=src/thirdparty

# [Cache & Performance]
# 도커 빌드/런타임 캐시 저장 경로 (ccache, uv, apt 등)
# 기본값: 현재 프로젝트 루트 내 .docker_cache
# 여러 프로젝트 간 동일 캐시를 공유하고 싶을 때만 아래 주석을 풀고 공통 절대 경로를 지정하세요.
# DOCKER_DEV_CACHE_DIR=/home/user/.global_docker_cache


# ─────────────────────────────────────────────────────────────────────────────
# 5. SYSTEM & BUILD TOOLS
# ─────────────────────────────────────────────────────────────────────────────

# APT_SNAPSHOT_DATE: 우분투 패키지 버전을 특정 날짜로 고정 (Strict Determinism)
# 항상 최신 버전을 쓰려면 'latest', 환경을 동결하려면 UTC 날짜 입력
# 예: APT_SNAPSHOT_DATE=20240301T000000Z
APT_SNAPSHOT_DATE=latest

# Locale & Timezone: 프로젝트의 표준 환경을 위해 기본적으로 C.UTF-8과 UTC를 사용합니다.
# LANG=C.UTF-8: 한국어 입출력을 지원하면서도 시스템 메시지(에러 등)는 영어로 출력되어 디버깅에 유리합니다.
LANG=C.UTF-8
TZ=UTC

# [Option] 한국어 시스템 메시지가 필요한 경우 (이미지 빌드 전 수정 권장)
# LANG=ko_KR.UTF-8

# [Build Specs] - 기본적으로 Makefile에서 자동 감지 및 주입됩니다.
# CMAKE_CXX_STANDARD: colcon build 시 -DCMAKE_CXX_STANDARD 로 전달됨 (지원: 17, 20)
CMAKE_CXX_STANDARD=17
UV_VERSION=0.10.10
UV_PYTHON=3.10
# TARGETARCH=amd64


# ─────────────────────────────────────────────────────────────────────────────
# 6. PRODUCTION & RUNTIME (Production Only)
# ─────────────────────────────────────────────────────────────────────────────

# IMAGE_TAG: 배포 이미지 빌드 시 사용할 태그 (기본값: latest)
IMAGE_TAG=latest

# [PROD] 배포 이미지 실행 명령어 (반드시 앱에 맞게 수정하세요)
# 설정하지 않을 경우 컨테이너 실행이 안전하게 중단됩니다.
# (예시)
# ROS_LAUNCH_COMMAND=ros2 launch bringup main.launch.py
# APP_COMMAND=python3 main.py

# (유휴 상태로 진입하고 싶을 때 - 비권장)
# ROS_LAUNCH_COMMAND=bash
# APP_COMMAND=bash


# ─────────────────────────────────────────────────────────────────────────────
# 7. HOST INTEGRATION (Git & SSH)
# ─────────────────────────────────────────────────────────────────────────────

# 컨테이너 내부에서 Git Commit/Push를 위해 호스트 설정을 공유 (Read-Only)
# sudo 실행 시에도 원래 사용자 설정을 유지하도록 설계되었습니다 (Smart Default).
# 표준 경로(~/.gitconfig,# Git & SSH 설정 (호스트 설정 공유)
# 기본값: ${HOST_HOME}/.gitconfig 및 ${HOST_HOME}/.ssh
# 특정 경로를 사용하고 싶을 때만 아래 주석을 풀고 절대 경로를 지정하세요.
# GIT_CONFIG_PATH=${HOST_HOME}/.gitconfig
# SSH_PATH=${HOST_HOME}/.ssh
