{
  // =========================================================================
  // .vscode/tasks.json
  // Build, test, and utility tasks for DevKit projects
  //
  // Supports ROS 1/2 workspace builds and CMake projects.
  // ROS version is auto-detected via the ROS_DISTRO environment variable.
  //
  // Execution Strategy:
  //   - When inside a Dev Container: tasks run directly in the container shell
  //   - When on the host: tasks use `docker exec` to reach the running container
  // =========================================================================
  "version": "2.0.0",
  "inputs": [
    {
      "id": "packageName",
      "type": "promptString",
      "description": "ROS package name to build (e.g., my_robot_pkg)"
    },
    {
      "id": "executablePath",
      "type": "promptString",
      "description": "Path to the executable to run (e.g., install/lib/my_pkg/my_node)"
    }
  ],
  "tasks": [
    // =====================================================================
    // ROS Workspace Build Tasks
    // =====================================================================
    {
      "label": "🔨 colcon: Build (Debug)",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && cbuild --debug'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Build all ROS packages with Debug symbols (required for GDB debugging)"
    },
    {
      "label": "🔨 colcon: Build (RelWithDebInfo)",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && cbuild'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Default development build — optimized with debug info"
    },
    {
      "label": "🔨 colcon: Build Package",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && cbuild --debug --pkg ${input:packageName}'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Build a single specific ROS package with Debug symbols"
    },
    {
      "label": "🔨 colcon: Build (Release)",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && cbuild --release'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Production-optimized build — maximum performance, no debug symbols"
    },
    // ── ROS Test Tasks ─────────────────────────────────────────────────
    {
      "label": "🧪 colcon: Test",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && cbt'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "test",
      "problemMatcher": [],
      "detail": "Run all ROS package tests with console output"
    },
    {
      "label": "🧪 colcon: Test Results",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && cbtr --verbose'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "test",
      "problemMatcher": [],
      "detail": "Display detailed test results summary"
    },

    // Pure C++ Build Tasks
    // =====================================================================
    {
      "label": "🔨 cmake: Build (Debug)",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && __mbuild_impl --debug'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Standard CMake Debug build for pure C++ projects"
    },
    {
      "label": "🔨 cmake: Build (Release)",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && __mbuild_impl --release'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Standard CMake Release build for pure C++ projects"
    },
    // =====================================================================
    // Python Tasks
    // =====================================================================
    {
      "label": "🐍 Python: uv sync",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && __uvs_impl'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Synchronize Python dependencies through the DevKit uvs alias logic"
    },
    {
      "label": "🐍 Python: Create venv",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && mkenv'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Create Python virtual environment through the DevKit mkenv alias logic"
    },
    // =====================================================================
    // Dependency Management
    // =====================================================================
    {
      "label": "🔄 Sync Dependencies",
      "type": "shell",
      "command": "bash \"${env:WS_SCRIPTS}/setup_sync_deps.sh\"",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Clone external repos from dependencies.repos and install rosdep packages"
    },
    {
      "label": "🔍 Check Dependencies (Sanity)",
      "type": "shell",
      "command": "bash \"${env:WS_SCRIPTS}/check_deps.sh\" \"${env:WS_INSTALL}\"",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Verify no missing shared libraries in install/ directory"
    },
    // =====================================================================
    // Workspace Utilities
    // =====================================================================
    {
      "label": "📋 Source ROS Workspace",
      "type": "shell",
      "command": "echo '⚠️  Use the terminal directly: source install/setup.bash (or use alias \"s\")'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Note: 'source' must be run in an interactive terminal to affect your shell session"
    },
    {
      "label": "🚀 Full Hardware & GPU Check",
      "type": "shell",
      "command": "bash \"${env:WS_SCRIPTS}/check_hardware.sh\"",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Comprehensive diagnostic for GPU, CUDA, Display, and WSL2 configuration"
    },
    {
      "label": "📦 Sync Workspace Dependencies",
      "type": "shell",
      "command": "bash \"${env:WS_SCRIPTS}/setup_sync_deps.sh\" --rosdep",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Pull external repositories and install missing rosdep dependencies"
    },
    {
      "label": "⚡ GPU Status & Diagnostics",
      "type": "shell",
      "command": "bash \"${env:WS_SCRIPTS}/setup_gpu.sh\" status",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Quick check of the active rendering mode and GPU driver visibility"
    },
    {
      "label": "✅ DevKit: Verify (Script-only)",
      "type": "shell",
      "command": "bash -lc 'ws_scripts=\"$WS_SCRIPTS\"; [ -n \"$ws_scripts\" ] || ws_scripts=/workspace/scripts; VERIFY_DOCKER=0 bash \"$ws_scripts/verify_repo.sh\"'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Run DevKit repository validation without Docker socket access"
    },
    {
      "label": "📊 Build Cache Statistics (ccache)",
      "type": "shell",
      "command": "ccache -s",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Show ccache hit/miss statistics and cache size usage"
    },
    {
      "label": "🧹 Clean Workspace",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && mclean && __remove_workspace_path \"$WS_LOGS\"'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "⚠️ WARNING: Removes all build artifacts — use with caution"
    },
    // =====================================================================
    // Pre-Debug Helper Tasks
    // =====================================================================
    {
      "label": "⚙️ Source & Build (Debug, pre-launch)",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && cbuild --debug && (__smart_source || true)'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Auto-detect ROS version → build (Debug) → source workspace",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "⚡ Source & Build Package (Debug, pre-launch)",
      "type": "shell",
      "command": "bash -lc 'source \"$WORKSPACE_PATH/config/util_aliases.sh\" && cbuild --debug --pkg ${input:packageName} && (__smart_source || true)'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "⚡ Fast: Build ONLY the specified package before debugging (turnaround optimization)",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}
