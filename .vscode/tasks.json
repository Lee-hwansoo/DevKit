{
  // =========================================================================
  // .vscode/tasks.json
  // Build, test, and utility tasks for DevKit projects
  //
  // Supports ROS 1/2 (colcon) & cmake build system.
  // ROS version is auto-detected via the ROS_DISTRO environment variable.
  //
  // Execution Strategy:
  //   - When inside a Dev Container: tasks run directly in the container shell
  //   - When on the host: tasks use `docker exec` to reach the running container
  // =========================================================================
  "version": "2.0.0",
  "inputs": [
    {
      "id": "packageName",
      "type": "promptString",
      "description": "ROS package name to build (e.g., my_robot_pkg)"
    },
    {
      "id": "executablePath",
      "type": "promptString",
      "description": "Path to the executable to run (e.g., install/lib/my_pkg/my_node)"
    }
  ],
  "tasks": [
    // =====================================================================
    // ROS Build Tasks (colcon)
    // =====================================================================
    {
      "label": "🔨 colcon: Build (Debug)",
      "type": "shell",
      "command": "(bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true); source /opt/ros/${ROS_DISTRO:-humble}/setup.bash 2>/dev/null; colcon build --symlink-install --install-base ${env:WS_INSTALL} --build-base ${env:WS_BUILD} --cmake-args -DCMAKE_BUILD_TYPE=Debug -DCMAKE_CXX_STANDARD=${env:CMAKE_CXX_STANDARD:17} -DCMAKE_C_STANDARD=${env:CMAKE_C_STANDARD:11} -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DPYTHON_EXECUTABLE=$(bash ${env:WS_SCRIPTS}/util_get_python.sh) $(bash ${env:WS_SCRIPTS}/setup_gpu.sh opencv_args 2>/dev/null || echo -DWITH_CUDA=OFF) && (bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true)",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Build all ROS 2 packages with Debug symbols (required for GDB debugging)"
    },
    {
      "label": "🔨 colcon: Build (RelWithDebInfo)",
      "type": "shell",
      "command": "(bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true); source /opt/ros/${ROS_DISTRO:-humble}/setup.bash 2>/dev/null; colcon build --symlink-install --install-base ${env:WS_INSTALL} --build-base ${env:WS_BUILD} --cmake-args -DCMAKE_BUILD_TYPE=RelWithDebInfo -DCMAKE_CXX_STANDARD=${env:CMAKE_CXX_STANDARD:17} -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DPYTHON_EXECUTABLE=$(bash ${env:WS_SCRIPTS}/util_get_python.sh) $(bash ${env:WS_SCRIPTS}/setup_gpu.sh opencv_args 2>/dev/null || echo -DWITH_CUDA=OFF) && (bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true)",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Default development build — optimized with debug info"
    },
    {
      "label": "🔨 colcon: Build Package",
      "type": "shell",
      "command": "(bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true); source /opt/ros/${ROS_DISTRO:-humble}/setup.bash 2>/dev/null; colcon build --symlink-install --install-base ${env:WS_INSTALL} --build-base ${env:WS_BUILD} --cmake-args -DCMAKE_BUILD_TYPE=Debug -DCMAKE_CXX_STANDARD=${env:CMAKE_CXX_STANDARD:17} -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DPYTHON_EXECUTABLE=$(bash ${env:WS_SCRIPTS}/util_get_python.sh) $(bash ${env:WS_SCRIPTS}/setup_gpu.sh opencv_args 2>/dev/null || echo -DWITH_CUDA=OFF) --packages-select ${input:packageName} && (bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true)",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Build a single specific ROS 2 package with Debug symbols"
    },
    {
      "label": "🔨 colcon: Build (Release)",
      "type": "shell",
      "command": "(bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true); source /opt/ros/${ROS_DISTRO:-humble}/setup.bash 2>/dev/null; colcon build --symlink-install --install-base ${env:WS_INSTALL} --build-base ${env:WS_BUILD} --cmake-args -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_STANDARD=${env:CMAKE_CXX_STANDARD:17} -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DPYTHON_EXECUTABLE=$(bash ${env:WS_SCRIPTS}/util_get_python.sh) $(bash ${env:WS_SCRIPTS}/setup_gpu.sh opencv_args 2>/dev/null || echo -DWITH_CUDA=OFF) && (bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true)",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Production-optimized build — maximum performance, no debug symbols"
    },
    // ── ROS Test Tasks ─────────────────────────────────────────────────
    {
      "label": "🧪 colcon: Test",
      "type": "shell",
      "command": "source /opt/ros/${ROS_DISTRO:-humble}/setup.bash && source ${env:WS_INSTALL}/setup.bash && colcon test --build-base ${env:WS_BUILD} --install-base ${env:WS_INSTALL} --event-handlers console_direct+",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "test",
      "problemMatcher": [],
      "detail": "Run all ROS package tests with console output"
    },
    {
      "label": "🧪 colcon: Test Results",
      "type": "shell",
      "command": "colcon test-result --build-base ${env:WS_BUILD} --verbose",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "test",
      "problemMatcher": [],
      "detail": "Display detailed test results summary"
    },

    // Pure C++ Build Tasks
    // =====================================================================
    {
      "label": "🔨 cmake: Build (Debug)",
      "type": "shell",
      "command": "mkdir -p ${env:WS_BUILD} && cd ${env:WS_BUILD} && cmake ../src -DCMAKE_BUILD_TYPE=Debug -DCMAKE_INSTALL_PREFIX=${env:WS_INSTALL} -DCMAKE_CXX_STANDARD=${env:CMAKE_CXX_STANDARD:17} -DCMAKE_C_STANDARD=${env:CMAKE_C_STANDARD:11} -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DPYTHON_EXECUTABLE=$(bash ${env:WS_SCRIPTS}/util_get_python.sh) && make -j$(nproc) install && (bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true)",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Standard CMake Debug build for pure C++ projects"
    },
    {
      "label": "🔨 cmake: Build (Release)",
      "type": "shell",
      "command": "mkdir -p ${env:WS_BUILD} && cd ${env:WS_BUILD} && cmake ../src -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=${env:WS_INSTALL} -DCMAKE_CXX_STANDARD=${env:CMAKE_CXX_STANDARD:17} -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DPYTHON_EXECUTABLE=$(bash ${env:WS_SCRIPTS}/util_get_python.sh) && make -j$(nproc) install && (bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true)",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Standard CMake Release build for pure C++ projects"
    },
    // =====================================================================
    // Python Tasks
    // =====================================================================
    {
      "label": "🐍 Python: uv sync",
      "type": "shell",
      "command": "uv sync --project ${env:WS_SRC} --extra ${UV_EXTRA:-cpu}",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Synchronize Python dependencies from pyproject.toml via uv"
    },
    {
      "label": "🐍 Python: Create venv",
      "type": "shell",
      "command": "mkdir -p ${env:WS_INSTALL} && uv venv \"${env:WS_VENV}\" --python ${env:UV_PYTHON:3.10} --seed --prompt \"${env:COMPOSE_PROJECT_NAME:-.venv}\" && bash ${env:WS_SCRIPTS}/util_setup_links.sh",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Create Python virtual environment in install/.venv (artifact separation)"
    },
    // =====================================================================
    // Dependency Management
    // =====================================================================
    {
      "label": "🔄 Sync Dependencies",
      "type": "shell",
      "command": "bash ${env:WS_SCRIPTS}/setup_sync_deps.sh",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Clone external repos from dependencies.repos and install rosdep packages"
    },
    {
      "label": "🔍 Check Dependencies (Sanity)",
      "type": "shell",
      "command": "bash ${env:WS_SCRIPTS}/check_deps.sh ${env:WS_INSTALL}",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Verify no missing shared libraries in install/ directory"
    },
    // =====================================================================
    // Workspace Utilities
    // =====================================================================
    {
      "label": "📋 Source ROS Workspace",
      "type": "shell",
      "command": "echo '⚠️  Use the terminal directly: source install/setup.bash (or use alias \"s\")'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Note: 'source' must be run in an interactive terminal to affect your shell session"
    },
    {
      "label": "🚀 Full Hardware & GPU Check",
      "type": "shell",
      "command": "bash ${env:WS_SCRIPTS}/check_hardware.sh",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Comprehensive diagnostic for GPU, CUDA, Display, and WSL2 configuration"
    },
    {
      "label": "📦 Sync Workspace Dependencies",
      "type": "shell",
      "command": "bash ${env:WS_SCRIPTS}/setup_sync_deps.sh --rosdep",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Pull external repositories and install missing rosdep dependencies"
    },
    {
      "label": "⚡ GPU Status & Diagnostics",
      "type": "shell",
      "command": "bash ${env:WS_SCRIPTS}/setup_gpu.sh status",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Quick check of the active rendering mode and GPU driver visibility"
    },
    {
      "label": "📊 Build Cache Statistics (ccache)",
      "type": "shell",
      "command": "ccache -s",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Show ccache hit/miss statistics and cache size usage"
    },
    {
      "label": "🧹 Clean Workspace",
      "type": "shell",
      "command": "rm -rf ${env:WS_BUILD} ${env:WS_INSTALL} ${env:WS_ROOT}/log && echo '✅ Workspace cleaned (build, install, log removed)'",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "⚠️ WARNING: Removes all build artifacts — use with caution"
    },
    {
      "label": "🏥 Hardware Check",
      "type": "shell",
      "command": "bash ${env:WS_SCRIPTS}/check_hardware.sh",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "problemMatcher": [],
      "detail": "Run full GPU/Display hardware diagnostics inside the container"
    },
    // =====================================================================
    // Pre-Debug Helper Tasks
    // =====================================================================
    {
      "label": "⚙️ Source & Build (Debug, pre-launch)",
      "type": "shell",
      "command": "(bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true); source /opt/ros/${ROS_DISTRO:-humble}/setup.bash 2>/dev/null; if command -v colcon &>/dev/null; then colcon build --symlink-install --install-base ${env:WS_INSTALL} --build-base ${env:WS_BUILD} ${COLCON_EXTRA_FLAGS} --cmake-args -DCMAKE_BUILD_TYPE=Debug -DCMAKE_CXX_STANDARD=${env:CMAKE_CXX_STANDARD:17} -DCMAKE_C_STANDARD=${env:CMAKE_C_STANDARD:11} -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DPYTHON_EXECUTABLE=$(bash ${env:WS_SCRIPTS}/util_get_python.sh) ${CMAKE_EXTRA_ARGS}; elif command -v catkin &>/dev/null; then catkin build --workspace ${env:WS_ROOT} -DCMAKE_BUILD_TYPE=Debug -DCMAKE_CXX_STANDARD=${env:CMAKE_CXX_STANDARD:17} -DCMAKE_C_STANDARD=${env:CMAKE_C_STANDARD:11} -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DPYTHON_EXECUTABLE=$(bash ${env:WS_SCRIPTS}/util_get_python.sh) ${CMAKE_EXTRA_ARGS}; fi && (bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true) && source ${env:WS_INSTALL}/setup.bash 2>/dev/null || source ${env:WS_ROOT}/devel/setup.bash 2>/dev/null || true",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Auto-detect ROS version → build (Debug) → source workspace",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "⚡ Source & Build Package (Debug, pre-launch)",
      "type": "shell",
      "command": "(bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true); source /opt/ros/${ROS_DISTRO:-humble}/setup.bash 2>/dev/null; if command -v colcon &>/dev/null; then colcon build --symlink-install --install-base ${env:WS_INSTALL} --build-base ${env:WS_BUILD} ${COLCON_EXTRA_FLAGS} --cmake-args -DCMAKE_BUILD_TYPE=Debug -DCMAKE_CXX_STANDARD=${env:CMAKE_CXX_STANDARD:17} -DCMAKE_C_STANDARD=${env:CMAKE_C_STANDARD:11} -DCMAKE_EXPORT_COMPILE_COMMANDS=ON ${CMAKE_EXTRA_ARGS} --packages-select ${input:packageName}; elif command -v catkin &>/dev/null; then catkin build --workspace ${env:WS_ROOT} --packages-select ${input:packageName} -DCMAKE_BUILD_TYPE=Debug -DCMAKE_CXX_STANDARD=${env:CMAKE_CXX_STANDARD:17} -DCMAKE_C_STANDARD=${env:CMAKE_C_STANDARD:11} -DCMAKE_EXPORT_COMPILE_COMMANDS=ON ${CMAKE_EXTRA_ARGS}; fi && (bash ${env:WS_SCRIPTS}/util_setup_links.sh 2>/dev/null || true) && (source ${env:WS_INSTALL}/setup.bash 2>/dev/null || source ${env:WS_ROOT}/devel/setup.bash 2>/dev/null || true)",
      "options": {
        "cwd": "${env:WS_ROOT}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "⚡ Fast: Build ONLY the specified package before debugging (turnaround optimization)",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}