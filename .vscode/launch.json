{
    // =========================================================================
    // .vscode/launch.json
    // Multi-layer debugging configurations for DevKit
    //
    // Supports:
    //   - C++ node debugging via GDB (launch & attach)
    //   - Python debugging via debugpy (local & remote attach)
    //   - ROS 2 (Humble) and ROS 1 (Noetic) launch & node debugging
    //   - Compound configurations for simultaneous multi-process debugging
    //
    // ROS version is auto-detected via the ROS_DISTRO environment variable.
    // All paths use /opt/ros/${env:ROS_DISTRO} for seamless ROS 1/2 switching.
    //
    // Prerequisites:
    //   - Build with Debug symbols: Ctrl+Shift+B → "🔨 colcon: Build (Debug)"
    //   - For Python remote debug: pip install debugpy (inside container)
    // =========================================================================
    "version": "0.2.0",
    "inputs": [
        {
            "id": "processId",
            "type": "command",
            "command": "extension.pickRemoteNativeProcess",
            "args": {}
        },
        {
            "id": "executablePath",
            "type": "promptString",
            "description": "Absolute path to executable (e.g., /workspace/install/lib/my_pkg/my_node)",
            "default": "/workspace/install/lib/"
        },
        {
            "id": "launchFile",
            "type": "promptString",
            "description": "Launch file path (e.g., src/my_pkg/launch/bringup.launch.py)",
            "default": "src/"
        },
        {
            "id": "rosPackage",
            "type": "promptString",
            "description": "ROS package name (e.g., my_robot_pkg)",
            "default": ""
        },
        {
            "id": "rosExecutable",
            "type": "promptString",
            "description": "ROS node executable name (e.g., my_node)",
            "default": ""
        },
        {
            "id": "pythonFile",
            "type": "promptString",
            "description": "Python file to debug (e.g., src/my_pkg/my_pkg/main.py)",
            "default": "${file}"
        },
        {
            "id": "debugpyPort",
            "type": "promptString",
            "description": "debugpy listen port (default: 5678)",
            "default": "5678"
        }
    ],
    "configurations": [
        // =====================================================================
        // C++ Debugging (GDB) — Works with both ROS 1 and ROS 2
        // =====================================================================
        {
            "name": "🐛 C++: Launch Executable (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${input:executablePath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "/workspace",
            "environment": [
                { "name": "LD_LIBRARY_PATH", "value": "/workspace/install/lib:/opt/ros/${env:ROS_DISTRO}/lib:${env:LD_LIBRARY_PATH}" },
                { "name": "AMENT_PREFIX_PATH", "value": "/workspace/install:/opt/ros/${env:ROS_DISTRO}" },
                { "name": "CMAKE_PREFIX_PATH", "value": "/workspace/install:/opt/ros/${env:ROS_DISTRO}" },
                { "name": "ROS_DISTRO", "value": "${env:ROS_DISTRO}" }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                { "text": "-enable-pretty-printing", "ignoreFailures": true },
                { "text": "set print thread-events off", "ignoreFailures": true },
                { "text": "set pagination off", "ignoreFailures": true }
            ],
            "preLaunchTask": "⚙️ Source & Build (Debug, pre-launch)",
            "sourceFileMap": {
                "/workspace/src": "${workspaceFolder}/src"
            },
            "logging": { "engineLogging": false }
        },
        {
            "name": "🐛 C++: Launch (GDB, skip build)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${input:executablePath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "/workspace",
            "environment": [
                { "name": "LD_LIBRARY_PATH", "value": "/workspace/install/lib:/opt/ros/${env:ROS_DISTRO}/lib:${env:LD_LIBRARY_PATH}" },
                { "name": "AMENT_PREFIX_PATH", "value": "/workspace/install:/opt/ros/${env:ROS_DISTRO}" },
                { "name": "CMAKE_PREFIX_PATH", "value": "/workspace/install:/opt/ros/${env:ROS_DISTRO}" },
                { "name": "ROS_DISTRO", "value": "${env:ROS_DISTRO}" }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                { "text": "-enable-pretty-printing", "ignoreFailures": true },
                { "text": "set print thread-events off", "ignoreFailures": true },
                { "text": "set pagination off", "ignoreFailures": true }
            ],
            "sourceFileMap": {
                "/workspace/src": "${workspaceFolder}/src"
            },
            "logging": { "engineLogging": false }
        },
        {
            "name": "🐛 C++: Attach to Process (GDB)",
            "type": "cppdbg",
            "request": "attach",
            "program": "${input:executablePath}",
            "processId": "${command:pickProcess}",
            "MIMode": "gdb",
            "setupCommands": [
                { "text": "-enable-pretty-printing", "ignoreFailures": true },
                { "text": "set print thread-events off", "ignoreFailures": true },
                { "text": "set pagination off", "ignoreFailures": true }
            ],
            "sourceFileMap": {
                "/workspace/src": "${workspaceFolder}/src"
            },
            "logging": { "engineLogging": false }
        },

        // =====================================================================
        // Python Debugging (debugpy) — Works with both ROS 1 and ROS 2
        // =====================================================================
        {
            "name": "🐍 Python: Debug Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "/workspace",
            "env": {
                "PYTHONPATH": "/workspace/src:/workspace/install/lib/python3/dist-packages:/opt/ros/${env:ROS_DISTRO}/lib/python3/dist-packages:${env:PYTHONPATH}"
            },
            "justMyCode": false
        },
        {
            "name": "🐍 Python: Debug with Args",
            "type": "debugpy",
            "request": "launch",
            "program": "${input:pythonFile}",
            "args": [],
            "console": "integratedTerminal",
            "cwd": "/workspace",
            "env": {
                "PYTHONPATH": "/workspace/src:/workspace/install/lib/python3/dist-packages:/opt/ros/${env:ROS_DISTRO}/lib/python3/dist-packages:${env:PYTHONPATH}"
            },
            "justMyCode": false
        },
        {
            "name": "🐍 Python: Attach to debugpy (Remote)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "/workspace"
                }
            ],
            "justMyCode": false
        },

        // =====================================================================
        // ROS 2 Launch Debugging (Humble and newer)
        // =====================================================================
        {
            "name": "🤖 ROS2: Launch File",
            "type": "debugpy",
            "request": "launch",
            "program": "/opt/ros/${env:ROS_DISTRO}/bin/ros2",
            "args": ["launch", "${input:launchFile}"],
            "console": "integratedTerminal",
            "cwd": "/workspace",
            "env": {
                "PYTHONPATH": "/workspace/install/lib/python3/dist-packages:/opt/ros/${env:ROS_DISTRO}/lib/python3/dist-packages:${env:PYTHONPATH}",
                "AMENT_PREFIX_PATH": "/workspace/install:/opt/ros/${env:ROS_DISTRO}",
                "LD_LIBRARY_PATH": "/workspace/install/lib:/opt/ros/${env:ROS_DISTRO}/lib",
                "ROS_DISTRO": "${env:ROS_DISTRO}",
                "RMW_IMPLEMENTATION": "${env:RMW_IMPLEMENTATION}"
            },
            "justMyCode": false,
            "preLaunchTask": "⚙️ Source & Build (Debug, pre-launch)"
        },
        {
            "name": "🤖 ROS2: Launch File (skip build)",
            "type": "debugpy",
            "request": "launch",
            "program": "/opt/ros/${env:ROS_DISTRO}/bin/ros2",
            "args": ["launch", "${input:launchFile}"],
            "console": "integratedTerminal",
            "cwd": "/workspace",
            "env": {
                "PYTHONPATH": "/workspace/install/lib/python3/dist-packages:/opt/ros/${env:ROS_DISTRO}/lib/python3/dist-packages:${env:PYTHONPATH}",
                "AMENT_PREFIX_PATH": "/workspace/install:/opt/ros/${env:ROS_DISTRO}",
                "LD_LIBRARY_PATH": "/workspace/install/lib:/opt/ros/${env:ROS_DISTRO}/lib",
                "ROS_DISTRO": "${env:ROS_DISTRO}",
                "RMW_IMPLEMENTATION": "${env:RMW_IMPLEMENTATION}"
            },
            "justMyCode": false
        },
        {
            "name": "🤖 ROS2: Run Node",
            "type": "debugpy",
            "request": "launch",
            "program": "/opt/ros/${env:ROS_DISTRO}/bin/ros2",
            "args": ["run", "${input:rosPackage}", "${input:rosExecutable}"],
            "console": "integratedTerminal",
            "cwd": "/workspace",
            "env": {
                "PYTHONPATH": "/workspace/install/lib/python3/dist-packages:/opt/ros/${env:ROS_DISTRO}/lib/python3/dist-packages:${env:PYTHONPATH}",
                "AMENT_PREFIX_PATH": "/workspace/install:/opt/ros/${env:ROS_DISTRO}",
                "LD_LIBRARY_PATH": "/workspace/install/lib:/opt/ros/${env:ROS_DISTRO}/lib",
                "ROS_DISTRO": "${env:ROS_DISTRO}"
            },
            "justMyCode": false
        },

        // =====================================================================
        // ROS 1 Launch Debugging (Noetic)
        // =====================================================================
        {
            "name": "🐢 ROS1: roslaunch",
            "type": "debugpy",
            "request": "launch",
            "program": "/opt/ros/${env:ROS_DISTRO}/bin/roslaunch",
            "args": ["${input:rosPackage}", "${input:launchFile}"],
            "console": "integratedTerminal",
            "cwd": "/workspace",
            "env": {
                "PYTHONPATH": "/workspace/install/lib/python3/dist-packages:/opt/ros/${env:ROS_DISTRO}/lib/python3/dist-packages:${env:PYTHONPATH}",
                "CMAKE_PREFIX_PATH": "/workspace/install:/opt/ros/${env:ROS_DISTRO}",
                "LD_LIBRARY_PATH": "/workspace/install/lib:/opt/ros/${env:ROS_DISTRO}/lib",
                "ROS_DISTRO": "${env:ROS_DISTRO}",
                "ROS_MASTER_URI": "${env:ROS_MASTER_URI}",
                "ROS_HOSTNAME": "${env:ROS_HOSTNAME}",
                "ROS_PACKAGE_PATH": "/workspace/src:/opt/ros/${env:ROS_DISTRO}/share"
            },
            "justMyCode": false,
            "preLaunchTask": "⚙️ Source & Build (Debug, pre-launch)"
        },
        {
            "name": "🐢 ROS1: rosrun",
            "type": "debugpy",
            "request": "launch",
            "program": "/opt/ros/${env:ROS_DISTRO}/bin/rosrun",
            "args": ["${input:rosPackage}", "${input:rosExecutable}"],
            "console": "integratedTerminal",
            "cwd": "/workspace",
            "env": {
                "PYTHONPATH": "/workspace/install/lib/python3/dist-packages:/opt/ros/${env:ROS_DISTRO}/lib/python3/dist-packages:${env:PYTHONPATH}",
                "CMAKE_PREFIX_PATH": "/workspace/install:/opt/ros/${env:ROS_DISTRO}",
                "LD_LIBRARY_PATH": "/workspace/install/lib:/opt/ros/${env:ROS_DISTRO}/lib",
                "ROS_DISTRO": "${env:ROS_DISTRO}",
                "ROS_MASTER_URI": "${env:ROS_MASTER_URI}",
                "ROS_HOSTNAME": "${env:ROS_HOSTNAME}",
                "ROS_PACKAGE_PATH": "/workspace/src:/opt/ros/${env:ROS_DISTRO}/share"
            },
            "justMyCode": false
        },

        // =====================================================================
        // C++ Node Direct Launch with GDB (ROS 1 & 2)
        // =====================================================================
        {
            "name": "🤖 ROS2: C++ Node (GDB Direct)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${input:executablePath}",
            "args": ["--ros-args", "-r", "__node:=${input:rosExecutable}"],
            "stopAtEntry": false,
            "cwd": "/workspace",
            "environment": [
                { "name": "LD_LIBRARY_PATH", "value": "/workspace/install/lib:/opt/ros/${env:ROS_DISTRO}/lib:${env:LD_LIBRARY_PATH}" },
                { "name": "AMENT_PREFIX_PATH", "value": "/workspace/install:/opt/ros/${env:ROS_DISTRO}" },
                { "name": "ROS_DISTRO", "value": "${env:ROS_DISTRO}" },
                { "name": "RMW_IMPLEMENTATION", "value": "${env:RMW_IMPLEMENTATION}" }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                { "text": "-enable-pretty-printing", "ignoreFailures": true },
                { "text": "set print thread-events off", "ignoreFailures": true }
            ],
            "sourceFileMap": {
                "/workspace/src": "${workspaceFolder}/src"
            },
            "preLaunchTask": "⚙️ Source & Build (Debug, pre-launch)"
        },
        {
            "name": "🐢 ROS1: C++ Node (GDB Direct)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${input:executablePath}",
            "args": ["__name:=${input:rosExecutable}"],
            "stopAtEntry": false,
            "cwd": "/workspace",
            "environment": [
                { "name": "LD_LIBRARY_PATH", "value": "/workspace/install/lib:/opt/ros/${env:ROS_DISTRO}/lib:${env:LD_LIBRARY_PATH}" },
                { "name": "CMAKE_PREFIX_PATH", "value": "/workspace/install:/opt/ros/${env:ROS_DISTRO}" },
                { "name": "ROS_DISTRO", "value": "${env:ROS_DISTRO}" },
                { "name": "ROS_MASTER_URI", "value": "${env:ROS_MASTER_URI}" },
                { "name": "ROS_HOSTNAME", "value": "${env:ROS_HOSTNAME}" },
                { "name": "ROS_PACKAGE_PATH", "value": "/workspace/src:/opt/ros/${env:ROS_DISTRO}/share" }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                { "text": "-enable-pretty-printing", "ignoreFailures": true },
                { "text": "set print thread-events off", "ignoreFailures": true }
            ],
            "sourceFileMap": {
                "/workspace/src": "${workspaceFolder}/src"
            },
            "preLaunchTask": "⚙️ Source & Build (Debug, pre-launch)"
        }
    ],

    // =========================================================================
    // Compound Launch Configurations
    // Launch multiple debug sessions simultaneously
    // =========================================================================
    "compounds": [
        {
            "name": "🚀 Full Debug: ROS2 Launch + C++ Attach",
            "configurations": [
                "🤖 ROS2: Launch File",
                "🐛 C++: Attach to Process (GDB)"
            ],
            "stopAll": true,
            "presentation": {
                "order": 1,
                "group": "compound"
            }
        },
        {
            "name": "🚀 Full Debug: ROS2 Launch + Python Attach",
            "configurations": [
                "🤖 ROS2: Launch File",
                "🐍 Python: Attach to debugpy (Remote)"
            ],
            "stopAll": true,
            "presentation": {
                "order": 2,
                "group": "compound"
            }
        },
        {
            "name": "🚀 Full Debug: ROS1 roslaunch + C++ Attach",
            "configurations": [
                "🐢 ROS1: roslaunch",
                "🐛 C++: Attach to Process (GDB)"
            ],
            "stopAll": true,
            "presentation": {
                "order": 3,
                "group": "compound"
            }
        },
        {
            "name": "🚀 Full Debug: ROS1 roslaunch + Python Attach",
            "configurations": [
                "🐢 ROS1: roslaunch",
                "🐍 Python: Attach to debugpy (Remote)"
            ],
            "stopAll": true,
            "presentation": {
                "order": 4,
                "group": "compound"
            }
        }
    ]
}
