# =============================================================================
# Git Attributes — LF 강제, 바이너리 처리
# =============================================================================

# 기본: 모든 텍스트 파일 LF
* text=auto eol=lf

# 명시적 텍스트 파일
*.sh      text eol=lf
*.bash    text eol=lf
*.py      text eol=lf
*.cpp     text eol=lf
*.hpp     text eol=lf
*.c       text eol=lf
*.h       text eol=lf
*.cmake   text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.json    text eol=lf
*.xml     text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.launch.py text eol=lf
Makefile  text eol=lf
Dockerfile text eol=lf
.env*     text eol=lf

# 바이너리 파일
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.ttf   binary
*.woff  binary
*.woff2 binary
*.zip   binary
*.tar   binary
*.gz    binary
*.deb   binary
*.so    binary
*.a     binary
