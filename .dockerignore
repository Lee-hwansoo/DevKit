# =============================================================================
# .dockerignore
# Exclude files and directories from the Docker build context
# =============================================================================

# Git
.git/
.gitignore
.gitattributes

# Build Artifacts
build/
install/
log/
.ccache/

# Thirdparty (Cloned inside the container via vcs import)
thirdparty/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
nosetests.xml

# C++ CMake cache
CMakeCache.txt
CMakeFiles/

# IDE
.vscode/
.idea/

# Environment (Security)
.env
.env.*

# Archives (Exclude by default, whitelist build-time dependencies)
*.zip
*.tar.gz
!dependencies/*.zip
!dependencies/*.tar.gz

# OS / System Files
**/.DS_Store
**/Thumbs.db

# Temporary & Backup Files
*~
*.bak
*.swp
*.patch
.history/

# Documentation
# *.md (Commented out to allow README.md access during build)
