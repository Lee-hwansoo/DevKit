# =============================================================================
# .dockerignore
# Exclude files and directories from the Docker build context
# =============================================================================

# AI
.agents/
.codex/

# Git
.git/
.gitignore
.gitattributes

# Build Artifacts
build/
install/
log/
logs/
-logs/
.ccache/
.docker_cache/
*.sif

# Thirdparty (Cloned inside the container via vcs import)
thirdparty/
third party deps/
src/thirdparty/*
!src/thirdparty/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/
env/
*.egg-info/
.eggs/
dist/
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
nosetests.xml

# C++ CMake cache
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
_build/

# IDE
.devcontainer/
.vscode/
.idea/

# Environment (Security)
.env
.env.*

# Archives (Exclude by default, whitelist build-time dependencies)
*.zip
*.tar.gz
!dependencies/*.zip
!dependencies/*.tar.gz

# OS / System Files
**/.DS_Store
**/Thumbs.db

# Temporary & Backup Files
*~
*.bak
*.swp
*.patch
.history/

# Documentation
# *.md (Commented out to allow README.md access during build)
